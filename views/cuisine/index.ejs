<%- contentFor('title') %>
    Cuisines Management

    <%- contentFor('body') %>
        <h1>All Cuisines</h1>
        <div>
            <a class="btn btn-primary" href="/cuisine/create">Create New Cuisine</a>
        </div>
        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Cuisine Name</th>
                </tr>
            </thead>
            <tbody>
                <% cuisines.forEach(c=> { %>
                    <tr>
                        <td>
                            <%= c.cuisine_id %>
                        </td>
                        <td>
                            <%= c.cuisine_name %>
                        </td>
                        <td>
                            <a class="btn btn-primary btn-sm" href="/cuisine/<%= c.cuisine_id %>/update">
                                Update
                            </a>
                            <a class="btn btn-danger btn-sm" href="/cuisine/<%= c.cuisine_id %>/delete">
                                Delete
                            </a>
                        </td>
                    </tr>
                    <% }) %>
            </tbody>
        </table>