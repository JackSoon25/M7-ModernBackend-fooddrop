<%- contentFor("title") %>
    Delete Vendor

    <%- contentFor("body") %>
        <form method="POST" class="mt-3">
            <div class = "alert alert-danger">Are you sure you want to delete the vendor <strong>
                    <%= vendor.vendor_name %>
                </strong>?
            </div>
            <div>
                <a href="/vendor" class="btn btn-success">Cancel</a>
                <button type = "submit" class = "btn btn-danger">
                    Delete
                </button>
            </div>
        </form>